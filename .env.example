# =============================================================================
# course-planner — environment variables (TEMPLATE ONLY)
# Copy this file to `.env.local` and fill in real values.
# `.env.local` / `.env` are gitignored and must NEVER be committed.
# =============================================================================

# --- Public (exposed to the browser, safe by design) -------------------------
# The ONLY Supabase values that may reach the client. Found in
# Supabase Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Server-only secrets (NEVER prefix with NEXT_PUBLIC) ----------------------
# Service role key bypasses RLS. Used only by the scraper / trusted server
# routes (lib/supabase/server.ts -> createServiceRoleClient). Never import into
# a client component; `server-only` enforces this at build time.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret required to trigger POST /api/scrape. The scheduled scraper must
# send it via the `x-scrape-secret` header; keeps the endpoint non-public.
SCRAPE_ADMIN_SECRET=

# Comma-separated emails allowed into the /admin backend (dashboard + one-click
# scrape). Only these logged-in users see /admin.
ADMIN_EMAILS=

# --- Rate limiting (optional in dev) -----------------------------------------
# In dev the app uses an in-memory limiter (no setup needed). For production /
# multi-instance deploys, set these to use Upstash Redis instead (see README).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Scraper config ----------------------------------------------------------
# Target semester for the source's SYearDDL param. NTU uses "1151" for 115-1.
# ("115-1" also works — the scraper normalises to digits.)
NTU_SEMESTER=1151
NTU_CLASSROOM_URL=https://gra206.aca.ntu.edu.tw/classrm/acarm/webcr-use-new
